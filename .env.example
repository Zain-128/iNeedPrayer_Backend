# Vercel sets PORT automatically; optional locally.
PORT=3004
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
# Optional: access vs refresh (social login returns both). Defaults match JWT_EXPIRES_IN / 7d.
# JWT_ACCESS_EXPIRES_IN=7d
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=your-refresh-secret-or-same-as-JWT_SECRET

# Fixed reset code (no email). Default 1234. Set a strong value before production.
# PASSWORD_RESET_CODE=1234

# Optional: restrict browser CORS (comma-separated). Omit for * (typical for React Native + JWT).
# ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Church verify screen stub (default 0000).
# CHURCH_VERIFY_CODE=0000

# Realtime chat: Socket.IO uses the same PORT as HTTP. Connect with socket.io-client
# and pass JWT: auth: { token: "<same as REST Bearer>" }.

# --- Vercel: set env vars in Project → Settings → Environment Variables.
# Use MongoDB Atlas MONGO_URI + JWT_SECRET. Prefer B2 for images (local /uploads is ephemeral on serverless).
# See docs/VERCEL.md

# --- Backblaze B2 image uploads (S3-compatible). If all are set, uploads go to B2; else local ./uploads ---
# B2_S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_REGION=us-west-004
# B2_KEY_ID=your_application_key_id
# B2_APPLICATION_KEY=your_application_key_secret
# B2_BUCKET=your-bucket-name
# B2_PUBLIC_URL_BASE=https://f005.backblazeb2.com/file/your-bucket-name
