PORT=3004
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Fixed reset code (no email). Default 1234. Set a strong value before production.
# PASSWORD_RESET_CODE=1234

# Optional: restrict browser CORS (comma-separated). Omit for * (typical for React Native + JWT).
# ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006

# Church verify screen stub (default 0000).
# CHURCH_VERIFY_CODE=0000

# Realtime chat: Socket.IO uses the same PORT as HTTP. Connect with socket.io-client
# and pass JWT: auth: { token: "<same as REST Bearer>" }.
